#multiple inheritence ---multiple parent classes ---single child class
class learner:
    def __init__(self):
        print('You are in learner stage')
    def fun1(self):
        print('this is the first parent class')
class expert:
    def __init__(self):
        print('you are now in level expert')
    def fun2(self):
        print('This is 2nd parent class')
class master(learner,expert):
    def __init__(self):
        learner.__init__(self) #calling first class
        expert.__init__(self) #calling 2nd class
        print('This is the child class')
        self.fun1()
        self.fun2()
obj = master()

